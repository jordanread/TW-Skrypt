{
  "entity": "character",
  "description": "Character entity belonging to a story.",
  "required": [
    "story-id",
    "skrypt-type",
    "skrypt-id",
    "name",
    "created",
    "modified"
  ],
  "fields": {
    "story-id": { "type": "string" },
    "skrypt-type": { "type": "string", "default": "character" },
    "skrypt-id": { "type": "string" },
    "name": { "type": "string" },
    "role": { "type": "string" },
    "archetype": { "type": "string" },
    "age": { "type": "number" },
    "gender": { "type": "string" },
    "description": { "type": "text" },
    "goals": { "type": "text" },
    "motivation": { "type": "text" },
    "conflict": { "type": "text" },
    "character-arc": { "type": "text" },
    "first-appearance": { "type": "string" },
    "created": { "type": "date" },
    "modified": { "type": "date" }
  }
}