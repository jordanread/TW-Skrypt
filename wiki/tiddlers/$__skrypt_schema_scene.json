{
  "entity": "scene",
  "description": "Primary writing unit containing narrative content.",
  "required": [
    "story-id",
    "manuscript-id",
    "chapter-id",
    "skrypt-type",
    "skrypt-id",
    "title",
    "scene-order",
    "created",
    "modified"
  ],
  "fields": {
    "story-id": { "type": "string" },
    "manuscript-id": { "type": "string" },
    "chapter-id": { "type": "string" },
    "skrypt-type": { "type": "string", "default": "scene" },
    "skrypt-id": { "type": "string" },
    "title": { "type": "string" },
    "scene-order": { "type": "number" },
    "pov-character": { "type": "string" },
    "location": { "type": "string" },
    "time": { "type": "string" },
    "status": { "type": "string" },
    "summary": { "type": "text" },
    "goal": { "type": "text" },
    "conflict": { "type": "text" },
    "outcome": { "type": "text" },
    "characters-present": { "type": "list" },
    "wordcount": { "type": "number" },
    "created": { "type": "date" },
    "modified": { "type": "date" }
  }
}